generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  email        String   @unique
  name         String
  role         String   @default("user")
  passwordHash String?
  favoriteTeam String   @default("")
  phone        String   @default("")
  newsletter   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Product {
  id           String   @id @default(cuid())
  name         String
  team         String
  price        Int
  images       String[]
  version      String[]
  sizes        String[]
  description  String
  rating       Float    @default(1)
  reviewCount  Int      @default(0)
  tags         String[]
  isMatchPick  Boolean  @default(true)
  isBestSeller Boolean  @default(false)
  createdAt    DateTime @default(now())
  reviews      Review[]
}

model Review {
  id        String   @id @default(cuid())
  productId String
  userId    String
  userName  String
  comment   String
  rating    Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
}

model Wishlist {
  id         String   @id @default(cuid())
  userId     String   @unique
  productIds String[]
  updatedAt  DateTime @updatedAt
}

model Order {
  id             String   @id @default(cuid())
  userId         String
  userEmail      String
  items          Json
  total          Float
  currency       String   @default("INR")
  paymentStatus  String   @default("created")
  shippingStatus String   @default("processing")
  createdAt      DateTime @default(now())
}
